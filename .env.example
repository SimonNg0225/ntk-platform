# 將呢個檔複製成 .env.local（.env.local 已被 git 排除，唔會 commit）
# 同樣兩個變數，記得喺 Vercel 專案 Settings → Environment Variables 都加返。
# 完整接入步驟（建 project、跑 SQL、Google 登入、部署 Gemini function）見 docs/SETUP.md

# Supabase 專案設定（Project Settings → API）
VITE_SUPABASE_URL=https://你的專案.supabase.co
VITE_SUPABASE_ANON_KEY=你的-anon-public-key

# 注意：
# - anon key 係可以公開放前端嘅（配合 RLS）。
# - 唔好喺前端放 service_role key，亦唔好放 Gemini key（Gemini key 之後設喺 Supabase Edge Function secret）。

# ───────── Google Drive 整合（教學資源庫，選用）─────────
# OAuth 用戶端 ID（可公開放前端）。未設定 → 教學資源庫嘅「Google Drive」分頁自動降級提示。
# 設定步驟見 docs/SETUP.md「Google Drive」一節。
VITE_GOOGLE_CLIENT_ID=你的-oauth-client-id.apps.googleusercontent.com

# ═════════════════════ 商業化（全部選用）═════════════════════
# 完整設定步驟見 docs/COMMERCIALIZATION.md。未設定就降級：
#   - 收費 → 定價頁顯示「即將推出」
#   - 監控 / 分析 → 完全 no-op（連 JS 都唔會載）

# ───────── Stripe 收費（前端只放 publishable + price，可公開）─────────
# secret key / webhook secret 唔好放呢度，要用 `supabase secrets set` 設喺 Edge Function。
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_你的-publishable-key
VITE_STRIPE_PRO_PRICE_ID=price_你的-pro-月費-price-id
# 年費 price（選用）：設咗定價頁先會出「月繳 / 年繳」切換
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=
# 團隊座位 price（選用，按座位 quantity 收費）：設咗「團隊 / 座位」先可購座位
VITE_STRIPE_TEAM_PRICE_ID=

# ───────── 客服系統 ─────────
# (A) 自家 in-app 聯絡表單：即裝即用（登入用戶 → support Edge Function →
#     存 ticket + email 客服）。客服收件箱用 Edge Function secret SUPPORT_EMAIL；
#     未接 Supabase / 未登入時前端用 mailto，地址用下面（可選）。
VITE_SUPPORT_EMAIL=support@eziteach.example
# (B) Crisp 即時聊天（選用）：設 website id → 同意 Cookie 後載入；設咗就用 Crisp
#     取代自家浮動掣。未設 → 用自家表單。
VITE_CRISP_WEBSITE_ID=

# ───────── Sentry 錯誤監控（選用）─────────
# DSN 設計成可放前端。未設 → 唔載 Sentry。
VITE_SENTRY_DSN=

# ───────── PostHog 產品分析（選用）─────────
# 未設 VITE_POSTHOG_KEY → 唔載 PostHog（零 bytes）。
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
